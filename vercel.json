{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(styles.css|main.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home-old", "destination": "/", "permanent": true },
    { "source": "/testimonial", "destination": "/testimonials", "permanent": true },
    { "source": "/past-events-gallery", "destination": "/podcast", "permanent": true },
    { "source": "/new-past-events-gallery", "destination": "/events", "permanent": true }
  ]
}
